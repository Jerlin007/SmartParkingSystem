      e.preventDefault();
      const res = await apiFetch("/lots/add", "POST", {
        lot_name:    document.getElementById("lot_name").value.trim(),
        location:    document.getElementById("location").value.trim(),
        total_slots: parseInt(document.getElementById("total_slots").value)
      });
      if (res && res.ok) {
        showMsg("lotMsg", "Lot added. ID: " + res.data.lot_id, "success");
        document.getElementById("lotForm").reset();
      } showMsg("slotMsg", res.data || "Failed to add slot.", "error");
    });

    // ── SLOTS ──
    document.getElementById("slotForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const res = await apiFetch("/slots/add", "POST", {
        slot_number:  document.getElementById("slot_number").value.trim(),
        slot_type:    document.getElementById("slot_type").value,
        status:       document.getElementById("slot_status").value,
        floor_number: parseInt(document.getElementById("floor_number").value),
        lot_id:       parseInt(document.getElementById("lot_id").value)
      });
      if (res && res.ok) {
        showMsg("slotMsg", "Slot added. ID: " + res.data.slot_id, "success");
        document.getElementById("slotForm").reset();
      } else showMsg("slotMsg", "Failed to add slot.", "error");
    });

    async function loadSlotsByLot() {
      const id = document.getElementById("lot_id_search").value;
      if (!id) return;
      const res = await apiFetch("/slots/lot/" + id);
      const tbody = document.getElementById("slotsByLotBody");
      tbody.innerHTML = "";
      if (res && res.ok) {
        res.data.forEach(s => {
          tbody.innerHTML += `<tr>
            <td>${s.slot_id}</td>
            <td>${s.slot_number}</td>
            <td>${s.slot_type}</td>
            <td>${s.floor_number}</td>
            <td>${statusBadge(s.status)}</td>
            <td style="display:flex;gap:6px;padding:8px 13px">
              <select id="st_${s.slot_id}" style="width:auto;padding:5px 8px;font-size:12px;flex:1">
                <option value="AVAILABLE">AVAILABLE</option>
                <option value="OCCUPIED">OCCUPIED</option>
                <option value="RESERVED">RESERVED</option>
              </select>
              <button class="btn btn-neutral" style="padding:5px 10px;font-size:11px" onclick="quickUpdate(${s.slot_id})">Set</button>
            </td>
          </tr>`;
        });
      }
    }

    async function quickUpdate(slotId) {
      const status = document.getElementById("st_" + slotId).value;
      const res = await apiFetch(`/slots/status/${slotId}?status=${status}`, "PUT");
      if (res && res.ok) { showMsg("updateSlotMsg", "Slot " + slotId + " updated.", "success"); loadSlotsByLot(); }
      else showMsg("updateSlotMsg", "Failed to update.", "error");
    }

    async function updateSlotStatus() {
      const slotId = document.getElementById("update_slot_id").value;
      const status = document.getElementById("new_status").value;
      if (!slotId) return;
      const res = await apiFetch(`/slots/status/${slotId}?status=${status}`, "PUT");
      if (res && res.ok) showMsg("updateSlotMsg", "Status updated.", "success");
      else showMsg("updateSlotMsg", "Failed.", "error");
    }

    // ── VEHICLES ──
    async function loadVehiclesByUser() {
      const uid = document.getElementById("admin_user_id").value;
      if (!uid) return;
      const res = await apiFetch("/vehicle/user/" + uid);
      const tbody = document.getElementById("adminVehicleBody");
      tbody.innerHTML = "";
      if (res && res.ok && res.data.length > 0) {
        clearMsg("adminVehicleMsg");
        res.data.forEach(v => {
          tbody.innerHTML += `<tr>
            <td>${v.vehicle_id}</td>
            <td>${v.vehicle_number}</td>
            <td>${v.vehicle_Type}</td>
            <td>${v.owner_name}</td>
            <td>${v.mobile_number}</td>
          </tr>`;
        });
      } else showMsg("adminVehicleMsg", "No vehicles found.", "error");
    }

    async function loadVehicleById() {
      const id = document.getElementById("vehicle_id_search").value;
      if (!id) return;
      const res = await apiFetch("/vehicle/" + id);
      const el = document.getElementById("vehicleByIdResult");
      if (res && res.ok) {
        const v = res.data;
        el.innerHTML = `<table class="detail-table">
          <tr><th>ID</th><td>${v.vehicle_id}</td></tr>
          <tr><th>Number</th><td>${v.vehicle_number}</td></tr>
          <tr><th>Type</th><td>${v.vehicle_Type}</td></tr>
          <tr><th>Owner</th><td>${v.owner_name}</td></tr>
          <tr><th>Mobile</th><td>${v.mobile_number}</td></tr>
        </table>`;
      } else el.innerHTML = `<p style="color:#c0392b;margin-top:10px;font-size:13px">Vehicle not found.</p>`;
    }

    // ── TRANSACTIONS ──
    document.getElementById("entryForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const res = await apiFetch("/transactions/entry", "POST", {
        vehicle_id: parseInt(document.getElementById("entry_vehicle_id").value),
        slot_id:    parseInt(document.getElementById("entry_slot_id").value),
        entry_time: document.getElementById("entry_time").value,
        status:     "ACTIVE"
      });
      if (res && res.ok) {
        showMsg("entryMsg", "Entry recorded. Transaction ID: " + res.data.transaction_id, "success");
        document.getElementById("entryForm").reset();
      } else showMsg("entryMsg", "Failed to record entry.", "error");
    });

    document.getElementById("exitForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const txnId = document.getElementById("exit_txn_id").value;
      const res = await apiFetch("/transactions/exit/" + txnId, "PUT", {
        exit_time: document.getElementById("exit_time").value,
        duration:  parseFloat(document.getElementById("duration").value),
        status:    "COMPLETED"
      });
      if (res && res.ok) {
        showMsg("exitMsg", "Exit recorded.", "success");
        document.getElementById("exitForm").reset();
      } else showMsg("exitMsg", "Failed to record exit.", "error");
    });

    async function loadTransaction() {
      const id = document.getElementById("txn_id_search").value;
      if (!id) return;
      const res = await apiFetch("/transactions/" + id);
      const el = document.getElementById("txnResult");
      if (res && res.ok) {
        const t = res.data;
        el.innerHTML = `<table class="detail-table">
          <tr><th>Transaction ID</th><td>${t.transaction_id}</td></tr>
          <tr><th>Vehicle ID</th><td>${t.vehicle_id}</td></tr>
          <tr><th>Slot ID</th><td>${t.slot_id}</td></tr>
          <tr><th>Entry Time</th><td>${fmt(t.entry_time)}</td></tr>
          <tr><th>Exit Time</th><td>${fmt(t.exit_time)}</td></tr>
          <tr><th>Duration</th><td>${t.duration ?? "-"} mins</td></tr>
          <tr><th>Status</th><td>${statusBadge(t.status)}</td></tr>
        </table>`;
      } else el.innerHTML = `<p style="color:#c0392b;margin-top:10px;font-size:13px">Transaction not found.</p>`;
    }

    // ── BILLING ──
    async function loadBilling() {
      const id = document.getElementById("bill_txn_id").value;
      if (!id) return;
      const res = await apiFetch("/billing/transaction/" + id);
      const el = document.getElementById("billingResult");
      if (res && res.ok) {
        const b = res.data;
        el.innerHTML = `<table class="detail-table">
          <tr><th>Bill ID</th><td>${b.bill_id}</td></tr>
          <tr><th>Amount</th><td>${b.amount}</td></tr>
          <tr><th>Tax</th><td>${b.tax}</td></tr>
          <tr><th>Total Amount</th><td><strong>${b.total_amount}</strong></td></tr>
          <tr><th>Payment Method</th><td>${b.payment_method || "-"}</td></tr>
          <tr><th>Payment Status</th><td>${statusBadge(b.payment_status)}</td></tr>
        </table>`;
      } else el.innerHTML = `<p style="color:#c0392b;margin-top:10px;font-size:13px">Billing not found for this transaction.</p>`;
    }
    
    async function loadBillingById() {
    	  const id = document.getElementById("bill_id_search").value;
    	  if (!id) return;
    	  const res = await apiFetch("/billing/" + id);
    	  const el = document.getElementById("billingByIdResult");
    	  if (res && res.ok) {
    	    const b = res.data;
    	    el.innerHTML = `<table class="detail-table">
    	      <tr><th>Bill ID</th><td>${b.bill_id}</td></tr>
    	      <tr><th>Amount</th><td>${b.amount}</td></tr>
    	      <tr><th>Tax</th><td>${b.tax}</td></tr>
    	      <tr><th>Total Amount</th><td><strong>${b.total_amount}</strong></td></tr>
    	      <tr><th>Payment Method</th><td>${b.payment_method || "-"}</td></tr>
    	      <tr><th>Payment Status</th><td>${statusBadge(b.payment_status)}</td></tr>
    	    </table>`;
    	  } else el.innerHTML = `<p style="color:#c0392b;margin-top:10px;font-size:13px">Bill not found.</p>`;
    	}
  </script>
</body>
</html>
</file>

<file path="src/main/resources/static/pages/dashboard.html">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard — Smart Parking</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <span class="brand">Smart Parking</span>
    <div class="nav-links">
      <a href="/pages/dashboard.html" class="active">My Vehicles</a>
      <a href="/pages/reservation.html">Reservations</a>
      <a href="/pages/payment.html">Payment</a>
      <a href="/pages/admin.html" id="adminLink" style="display:none">Admin Panel</a>
      <a href="#" class="logout" onclick="logout()">Logout</a>
    </div>
  </nav>

  <div class="container">
    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('myvehicles', this)">My Vehicles</button>
      <button class="tab-btn" onclick="switchTab('addvehicle', this)">Add Vehicle</button>
    </div>

    <!-- MY VEHICLES -->
    <div id="tab-myvehicles" class="tab-content active">
      <div class="card">
        <h2>My Vehicles</h2>
        <div class="inline-row">
          <input type="number" id="fetch_user_id" placeholder="Your User ID">
          <button class="btn btn-primary" onclick="loadVehicles()">Load</button>
        </div>
        <div id="vehicleMsg" class="msg"></div>
        <table>
          <thead>
            <tr><th>ID</th><th>Number</th><th>Type</th><th>Owner</th><th>Mobile</th></tr>
          </thead>
          <tbody id="vehicleBody"></tbody>
        </table>
      </div>
    </div>

    <!-- ADD VEHICLE -->
    <div id="tab-addvehicle" class="tab-content">
      <div class="card">
        <h2>Add Vehicle</h2>
        <div id="addMsg" class="msg"></div>
        <form id="addForm">
          <div class="form-group">
            <label>Vehicle Number</label>
            <input type="text" id="vehicle_number" required>
          </div>
          <div class="form-group">
            <label>Vehicle Type</label>
            <select id="vehicle_Type">
              <option value="CAR">CAR</option>
              <option value="BIKE">BIKE</option>
              <option value="TRUCK">TRUCK</option>
            </select>
          </div>
          <div class="form-group">
            <label>Owner Name</label>
            <input type="text" id="owner_name" required>
          </div>
          <div class="form-group">
            <label>Mobile Number</label>
            <input type="text" id="mobile_number" required>
          </div>
          <div class="form-group">
            <label>Your User ID</label>
            <input type="number" id="user_id" required>
          </div>
          <button type="submit" class="btn btn-primary">Add Vehicle</button>
        </form>
      </div>
    </div>
  </div>

  <script src="/js/api.js"></script>
  <script>
    requireAuth();
    // Show admin link only if role is ADMIN
    if (getRole() === "ADMIN") document.getElementById("adminLink").style.display = "inline";

    async function loadVehicles() {
      const uid = document.getElementById("fetch_user_id").value;
      if (!uid) { showMsg("vehicleMsg", "Please enter your User ID.", "error"); return; }
      const res = await apiFetch("/vehicle/user/" + uid);
      const tbody = document.getElementById("vehicleBody");
      tbody.innerHTML = "";
      if (res && res.ok && res.data.length > 0) {
        clearMsg("vehicleMsg");
        res.data.forEach(v => {
          tbody.innerHTML += `<tr>
            <td>${v.vehicle_id}</td>
            <td>${v.vehicle_number}</td>
            <td>${v.vehicle_Type}</td>
            <td>${v.owner_name}</td>
            <td>${v.mobile_number}</td>
          </tr>`;
        });
      } else {
        showMsg("vehicleMsg", res && res.status === 403
          ? "Session expired. Please login again."
          : "No vehicles found for this user.", "error");
      }
    }

    document.getElementById("addForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const body = {
        vehicle_number: document.getElementById("vehicle_number").value.trim(),
        vehicle_Type:   document.getElementById("vehicle_Type").value,
        owner_name:     document.getElementById("owner_name").value.trim(),
        mobile_number:  document.getElementById("mobile_number").value.trim(),
        user_id:        parseInt(document.getElementById("user_id").value)
      };
      const res = await apiFetch("/vehicle/add", "POST", body);
      if (res && res.ok) {
        showMsg("addMsg", "Vehicle added successfully. ID: " + res.data.vehicle_id, "success");
        document.getElementById("addForm").reset();
      } else {
        showMsg("addMsg", "Failed to add vehicle. Check all fields.", "error");
      }
    });
  </script>
</body>
</html>
</file>

<file path="src/main/resources/static/pages/login.html">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login — Smart Parking</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-card">
    <h2>Smart Parking</h2>
    <p class="subtitle">Sign in to your account</p>
    <div id="msg" class="msg"></div>
    <form id="form">
      <div class="form-group">
        <label>Email</label>
        <input type="email" id="email" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Sign In</button>
    </form>
    <p class="footer-link">No account? <a href="/pages/register.html">Register</a></p>
  </div>

  <script src="/js/api.js"></script>
  <script>
    redirectIfLoggedIn();

    document.getElementById("form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const res = await apiFetch("/auth/login", "POST", {
        email:    document.getElementById("email").value.trim(),
        password: document.getElementById("password").value
      });

      if (res && res.ok) {
        const token = res.data.token;
        const role  = res.data.role || "USER";
        localStorage.setItem("token", token);
        localStorage.setItem("role", role);
        window.location.href = role === "ADMIN" ? "/pages/admin.html" : "/pages/dashboard.html";
      } else {
        showMsg("msg", "Invalid email or password.", "error");
      }
    });
  </script>
</body>
</html>
